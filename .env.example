# Google Maps (renderer)
VITE_GOOGLE_MAPS_API_KEY=

# Public API (renderer + server)
VITE_API_URL=http://localhost:3001
API_URL=http://localhost:3001
API_PORT=3001
DATABASE_URL=postgres://porkauto:porkauto@localhost:5432/porkauto
JWT_SECRET=dev-change-me-to-a-long-random-string

# Dev HUD: indev cycle, reset setup, “Skip setup (dev)” on the pairing screen
# VITE_DEV_TOOLS=true

# Spotify (connected service — Premium + Developer Dashboard app required)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match Dashboard exactly. Companion deep link (recommended for phone linking):
SPOTIFY_REDIRECT_URI=porkauto://oauth/spotify
# Or HTTPS tunnel + server callback:
# SPOTIFY_REDIRECT_URI=https://YOUR-TUNNEL.trycloudflare.com/integrations/spotify/callback
# After HTTPS server callback, deep-link back into the Android companion
SPOTIFY_ANDROID_REDIRECT=porkauto://oauth/spotify
