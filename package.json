{
  "name": "porkauto",
  "version": "0.0.1",
  "description": "A simple Electrobun app showcasing core features",
  "scripts": {
    "dev": "bun run dev:renderer & bun run dev:app",
    "dev:renderer": "vite",
    "dev:app": "RENDERER_URL=http://localhost:5173 electrobun dev",
    "build": "vite build && electrobun build",
    "start": "bun run build && bun run dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electrobun": "latest",
    "lucide-react": "^0.552.0",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "latest"
  }
}