{
  "name": "porkauto",
  "version": "0.0.1",
  "description": "Standalone car display — CarPlay/Android Auto alternative",
  "scripts": {
    "dev": "bun run db:up && bun run dev:all",
    "dev:all": "bun ./scripts/dev.ts",
    "dev:renderer": "vite --host",
    "dev:app": "RENDERER_URL=http://localhost:5173 electrobun dev",
    "dev:tunnel": "bun ./scripts/dev-tui.ts",
    "dev:api": "bun run --hot server/src/index.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "bun run server/src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "build": "vite build && electrobun build",
    "start": "bun run build && bun run dev",
    "typecheck": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@opentui/core": "^0.4.3",
    "@tailwindcss/vite": "^4.1.16",
    "@vis.gl/react-google-maps": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.3",
    "electrobun": "latest",
    "hono": "^4.7.4",
    "jose": "^6.0.8",
    "lucide-react": "^0.552.0",
    "maplibre-gl": "^5.24.0",
    "path": "^0.12.7",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/google.maps": "^3.58.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "drizzle-kit": "^0.30.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "vite": "latest"
  }
}
